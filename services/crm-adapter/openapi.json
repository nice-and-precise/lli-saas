            "$ref": "#/components/schemas/BoardMapping"
          },
          "validation": {
            "$ref": "#/components/schemas/ValidationResponse"
          }
        },
        "required": [
          "tenant_id",
          "board_id",
          "mapping"
        ],
        "additionalProperties": true
      },

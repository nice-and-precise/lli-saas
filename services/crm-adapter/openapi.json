{
  "openapi": "3.1.0",
  "info": {
    "title": "LLI Data Intake API",
    "version": "0.1.0",
    "summary": "Self-service API contract for broker CRM data intake and lead delivery configuration.",
    "description": "OpenAPI contract for the lli-saas crm-adapter service. This spec documents the routes brokers or their IT teams use to connect Monday.com, validate setup, fetch normalized owner records, configure destination-board mapping, and submit canonical obituary lead payloads for delivery."
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local crm-adapter default"
    },
    {
      "url": "https://crm-adapter.lli-saas.local",
      "description": "Illustrative deployed endpoint"
    }
  ],
  "tags": [
    {
      "name": "Health"
    },
    {
      "name": "Auth"
    },
    {
      "name": "Boards"
    },
    {
      "name": "Owners"
    },
    {
      "name": "Validation"
    },
    {
      "name": "Mapping"
    },
    {
      "name": "Leads"
    },
    {
      "name": "Status"
    }
  ],
  "components": {
    "securitySchemes": {
      "TenantHeader": {
        "type": "apiKey",
        "in": "header",
        "name": "x-tenant-id",
        "description": "Optional tenant selector. Defaults to `pilot` when omitted."
      }
    },
    "parameters": {
      "TenantHeader": {
        "name": "x-tenant-id",
        "in": "header",
        "required": false,
        "schema": {
          "type": "string",
          "minLength": 1
        },
        "description": "Optional tenant scope for saved OAuth, board, mapping, scan, and delivery state. Defaults to `pilot`."
      },
      "Limit": {
        "name": "limit",
        "in": "query",
        "required": false,
        "schema": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10000,
          "default": 10000
        },
        "description": "Maximum number of owner records to fetch from the Monday Clients board."
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "error": {
            "type": "string"
          },
          "details": {
            "type": "string"
          }
        },
        "required": [
          "error"
        ]
      },
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "ok"
            ]
          },
          "service": {
            "type": "string",
            "enum": [
              "crm-adapter"
            ]
          },
          "monday_oauth_configured": {
            "type": "boolean"
          },
          "source_owner_board_name": {
            "type": "string"
          },
          "token_store_path": {
            "type": "string"
          }
        },
        "required": [
          "status",
          "service",
          "monday_oauth_configured",
          "source_owner_board_name",
          "token_store_path"
        ]
      },
      "ReadyResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "ready"
            ]
          },
          "service": {
            "type": "string",
            "enum": [
              "crm-adapter"
            ]
          }
        },
        "required": [
          "status",
          "service"
        ]
      },
      "NotReadyResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "not_ready"
            ]
          },
          "service": {
            "type": "string",
            "enum": [
              "crm-adapter"
            ]
          },
          "missing_configuration": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "status",
          "service",
          "missing_configuration"
        ]
      },
      "ContractResponse": {
        "type": "object",
        "properties": {
          "lead_contract_path": {
            "type": "string"
          },
          "owner_record_contract_path": {
            "type": "string"
          }
        },
        "required": [
          "lead_contract_path",
          "owner_record_contract_path"
        ]
      },
      "BoardColumn": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "type": {
            "type": "string"
          }
        },
        "required": [
          "id"
        ]
      },
      "Board": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "columns": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BoardColumn"
            }
          }
        },
        "required": [
          "id",
          "name"
        ]
      },
      "BoardsResponse": {
        "type": "object",
        "properties": {
          "boards": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Board"
            }
          },
          "selected_board": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/Board"
              },
              {
                "type": "null"
              }
            ]
          },
          "tenant_id": {
            "type": "string"
          }
        },
        "required": [
          "boards",
          "selected_board",
          "tenant_id"
        ]
      },
      "SelectBoardRequest": {
        "type": "object",
        "properties": {
          "board_id": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "board_id"
        ],
        "additionalProperties": false
      },
      "BoardMapping": {
        "type": "object",
        "description": "Maps canonical lead summary fields onto Monday destination columns.",
        "properties": {
          "item_name_strategy": {
            "type": "string",
            "enum": [
              "deceased_name_county",
              "deceased_name_only",
              "deceased_name_address"
            ]
          },
          "columns": {
            "type": "object",
            "description": "Dictionary of canonical field name -> Monday column id.",
            "additionalProperties": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "required": [
          "item_name_strategy",
          "columns"
        ],
        "additionalProperties": false
      },
      "ValidationResponse": {
        "type": "object",
        "additionalProperties": true,
        "description": "Current Monday connectivity and board-mapping validation snapshot."
      },
      "SelectedBoardResponse": {
        "type": "object",
        "properties": {
          "selected_board": {
            "$ref": "#/components/schemas/Board"
          },
          "tenant_id": {
            "type": "string"
          },
          "validation": {
            "$ref": "#/components/schemas/ValidationResponse"
          }
        },
        "required": [
          "selected_board",
          "tenant_id",
          "validation"
        ]
      },
      "MappingResponse": {
        "type": "object",
        "properties": {
          "tenant_id": {
            "type": "string"
          },
          "board_id": {
            "type": "string"
          },

    "/leads": {
      "post": {
        "tags": [
          "Leads"
        ],
        "summary": "Validate and deliver a canonical obituary lead payload to the selected Monday board",
        "description": "This is the primary self-service intake endpoint for downstream integrations. The payload must match the canonical lead contract. Duplicate and retry protection is enforced via deterministic transaction IDs and lead identity matching.",
        "parameters": [
          {
            "$ref": "#/components/parameters/TenantHeader"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {

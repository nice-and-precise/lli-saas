{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lli-saas.local/contracts/lead.schema.json",
  "title": "Lead",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "scan_id",
    "source",
    "run_started_at",
    "run_completed_at",
    "owner_id",
    "owner_name",
    "deceased_name",
    "property",
    "heirs",
    "obituary",
    "match",
    "tier",
    "out_of_state_heir_likely",
    "out_of_state_states",
    "executor_mentioned",
    "unexpected_death",
    "notes",
    "tags",
    "raw_artifacts",
    "owner_profile_url",
    "obituary_raw_url"
  ],
  "properties": {
    "scan_id": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "run_started_at": {
      "type": "string",
      "format": "date-time"
    },
    "run_completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "owner_id": {
      "type": "string",
      "minLength": 1
    },
    "owner_name": {
      "type": "string",
      "minLength": 1
    },
    "deceased_name": {
      "type": "string",
      "minLength": 1
    },
    "property": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "county",
        "state",
        "acres",
        "parcel_ids",
        "address_line_1",
        "city",
        "postal_code",
        "operator_name"
      ],
      "properties": {
        "county": {
          "type": [
            "string",
            "null"
          ]
        },
        "state": {
          "type": [
            "string",
            "null"
          ]
        },
        "acres": {
          "type": [
            "number",
            "null"
          ]
        },
        "parcel_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "address_line_1": {
          "type": [
            "string",
            "null"
          ]
        },
        "city": {
          "type": [
            "string",
            "null"
          ]
        },
        "postal_code": {
          "type": [
            "string",
            "null"
          ]
        },
        "operator_name": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "heirs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "relationship",
          "location_city",
          "location_state",
          "out_of_state",
          "phone",
          "email",
          "mailing_address",
          "executor"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "relationship": {
            "type": "string",
            "minLength": 1
          },
          "location_city": {
            "type": [
              "string",
              "null"
            ]
          },
          "location_state": {
            "type": [
              "string",
              "null"
            ]
          },
          "out_of_state": {
            "type": "boolean"
          },
          "phone": {
            "type": [
              "string",
              "null"
            ]
          },
          "email": {
            "type": [
              "string",
              "null"
            ]
          },
          "mailing_address": {
            "type": [
              "string",
              "null"
            ]
          },
          "executor": {
            "type": "boolean"
          }
        }
      }
    },
    "obituary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "url",
        "source_id",
        "published_at",
        "death_date",
        "deceased_city",
        "deceased_state"
      ],
      "properties": {
        "url": {
          "type": "string",
          "minLength": 1
        },
        "source_id": {
          "type": "string",
          "minLength": 1
        },
        "published_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "death_date": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        },
        "deceased_city": {
          "type": [
            "string",
            "null"
          ]
        },
        "deceased_state": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "match": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "score",
        "last_name_score",
        "first_name_score",
        "location_bonus_applied",
        "status",
        "matched_fields",
        "explanation"
      ],
      "properties": {
        "score": {
          "type": "number"
        },
        "last_name_score": {
          "type": "number"
        },
        "first_name_score": {
          "type": "number"
        },
        "location_bonus_applied": {
          "type": "boolean"
        },
        "status": {
          "type": "string",
          "enum": [
            "auto_confirmed",
            "pending_review"
          ]
        },
        "confidence_band": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "high",
            "medium",
            "low",
            null
          ]
        },
        "matched_fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "explanation": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "explanation_details": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "component",
              "score",
              "weight",
              "matched",
              "evidence"
            ],
            "properties": {
              "component": {
                "type": "string"
              },
              "score": {
                "type": "number"
              },
              "weight": {
                "type": "number"
              },
              "matched": {
                "type": "boolean"
              },
              "evidence": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "tier": {
      "type": "string",
      "enum": [
        "hot",
        "warm",
        "pending_review",
        "low_signal"
      ]
    },
    "out_of_state_heir_likely": {
      "type": "boolean"
    },
    "out_of_state_states": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "executor_mentioned": {
      "type": "boolean"
    },
    "unexpected_death": {
      "type": "boolean"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "raw_artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "owner_profile_url": {
      "type": [
        "string",
        "null"
      ],
      "format": "uri"
    },
    "obituary_raw_url": {
      "type": [
        "string",
        "null"
      ],
      "format": "uri"
    }
  }
}
